# Core Django settings
SECRET_KEY=change-me-for-production
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_CREDENTIALS=False

# Database
# Leave blank for local SQLite. Use postgres://USER:PASSWORD@HOST:PORT/DB_NAME for production.
DATABASE_URL=

# OpenAI feedback drafting
OPENAI_API_KEY=your_openai_api_key

# Gmail SMTP feedback delivery
GMAIL_USER=your_gmail_address@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password
DEFAULT_FROM_EMAIL=CoreGuard <your_gmail_address@gmail.com>
